# PostgreSQL
POSTGRES_USER=auth_user
POSTGRES_PASSWORD=
POSTGRES_DB=auth_db
POSTGRES_PORT=5434
POSTGRES_HOST=localhost

# Prisma
DATABASE_URL="postgresql://auth_user:YOUR_PASSWORD@localhost:5434/auth_db"

# Redis
REDIS_URL=redis://localhost:6380

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Token TTLs — must stay in sync with ACCESS_TOKEN_EXPIRY and REFRESH_TOKEN_EXPIRY
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_MS=604800000

# CSRF — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=

# App
NODE_ENV=development
PORT=4000
